{
  "name": "@dijla-ventures-llc/dryft",
  "version": "0.1.4",
  "description": "Static analysis for feature integrity in the age of AI.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "dryft": "dist/src/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dijla-ventures-llc/dryft.git"
  },
  "bugs": {
    "url": "https://github.com/dijla-ventures-llc/dryft/issues"
  },
  "homepage": "https://github.com/dijla-ventures-llc/dryft#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "npm run build && node scripts/run-tests.mjs"
  },
  "dependencies": {
    "picomatch": "^4.0.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24"
  }
}
